{
  "name": "Pred Market",
  "build": {
    "dockerfile": "../services/Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/app",
  
  // 1. Run as a non-root user (prevents permission issues on Linux host)
  "remoteUser": "vscode", 

  "remoteEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}"
  },
  
  // 2. Add useful standard Dev Container features
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  // 3. Automatically forward your application's port (change 8000 to your app's port)
  "forwardPorts": [8000],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",            // Essential for Python debugging
        "charliermarsh.ruff",           // Extremely fast modern linter/formatter
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true,
        
        // 4. Quality of life: Auto-formatting on save
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        }
      }
    }
  },

  // 5. Upgrade pip first, and prefer updateContentCommand over postCreateCommand
  "updateContentCommand": "pip install --upgrade pip && pip install -r services/requirements.txt"
}